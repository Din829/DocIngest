# DocIngest Environment Configuration
# Copy this file to .env and fill in what you need.
# All values are optional — uncomment and set only what applies to you.
#
# Alternative for Python library users: pass keys via Provider classes
# (e.g. docingest.GeminiProvider(api_key=...)) instead of env vars.
# See README "Python Library" section for the full example.

# =============================================================================
# API Keys (only needed if using Vision AI or audio transcription)
# =============================================================================

# Vision AI — default primary engine
GEMINI_API_KEY=

# Audio transcription — default ASR engine (Qwen3-ASR-Flash)
DASHSCOPE_API_KEY=

# Optional fallback for Vision/ASR
# OPENAI_API_KEY=

# =============================================================================
# Config overrides (any config/default.yaml value can be overridden here)
# Format: DOCINGEST__<section>__<key>=<value>  (double underscore separator)
# Full config reference: config/default.yaml
# =============================================================================

# --- Vision ---
# DOCINGEST__parsing__vision__enabled=true
# DOCINGEST__parsing__vision__max_pages=50
# DOCINGEST__parsing__vision__image_dpi=180
# DOCINGEST__parsing__vision__triage__enabled=false

# --- Chunking ---
# DOCINGEST__chunking__strategy=auto
# DOCINGEST__chunking__max_tokens=512

# --- Refine ---
# DOCINGEST__refine__max_input_tokens=50000

# --- Output ---
# DOCINGEST__output__dir=./knowledge
# DOCINGEST__output__include_bounding_boxes=true

# --- Sanitize (PII masking, default OFF) ---
# DOCINGEST__sanitize__enabled=false

# --- Incremental cache ---
# DOCINGEST__incremental__enabled=true
