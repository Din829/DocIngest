# DocIngest API Keys
# Copy this file to .env and fill in your keys.
#
# Only the keys you actually need — no Vision/audio = no keys needed.

# === Vision AI (per-page document enrichment) ===
# Default primary engine. Required if parsing.vision.enabled = true.
GEMINI_API_KEY=

# === Audio Transcription ===
# Default ASR engine (Qwen3-ASR-Flash). Required for audio/video processing.
DASHSCOPE_API_KEY=

# === Optional Fallback ===
# Used as fallback when primary Vision/ASR fails.
# OPENAI_API_KEY=
